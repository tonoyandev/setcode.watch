{
  "name": "@setcode/watcher",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "SetCode.watch alerting service: Telegram bot + alert dispatcher",
  "license": "MIT",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsx --watch src/index.ts",
    "start": "tsx src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@setcode/shared": "workspace:*",
    "drizzle-orm": "^0.38.2",
    "hono": "^4.6.13",
    "nanoid": "^5.0.9",
    "pg": "^8.13.1",
    "postgres": "^3.4.5",
    "telegraf": "^4.16.3",
    "tsx": "^4.19.2",
    "viem": "^2.21.45",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.13",
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
