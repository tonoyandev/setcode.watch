# Postgres connection URL (shared with @setcode/indexer in docker-compose).
# Format: postgres://user:password@host:port/database
DATABASE_URL=

# Telegram bot token — from @BotFather.
# Required for bot and dispatcher processes; not required for db:migrate.
TELEGRAM_BOT_TOKEN=

# Bot username (without @). Used to build deep-links shown on the web UI.
TELEGRAM_BOT_USERNAME=

# Confirmation code TTL in seconds. Default: 300 (5 minutes).
CONFIRMATION_TTL_SECONDS=300

# Alert retention window in days. Rows in alerts_sent older than this
# are eligible for deletion by the retention job. Default: 90.
ALERT_RETENTION_DAYS=90

# Max confirmed subscriptions per Telegram chat (soft anti-abuse limit).
# Default: 10.
MAX_SUBSCRIPTIONS_PER_CHAT=10

# HTTP API port. Used by the Nuxt app to create confirmation links.
# Default: 8787.
WATCHER_HTTP_PORT=8787

# Comma-separated allowed CORS origins for the HTTP API.
# Default: http://localhost:3000
WATCHER_CORS_ORIGIN=http://localhost:3000
