# Postgres connection URL (shared with @setcode/indexer in docker-compose).
# Format: postgres://user:password@host:port/database
DATABASE_URL=

# Postgres schema where the indexer (Ponder) writes its onchain tables. Must
# match `DATABASE_SCHEMA` on the indexer service. Tests leave this unset
# (defaults to `public`) because the pglite fixture installs tables there.
WATCHER_PONDER_SCHEMA=indexer

# Telegram bot token — from @BotFather.
# Required for bot and dispatcher processes; not required for db:migrate.
TELEGRAM_BOT_TOKEN=

# Bot username (without @). Used to build deep-links shown on the web UI.
TELEGRAM_BOT_USERNAME=

# Confirmation code TTL in seconds. Default: 300 (5 minutes).
CONFIRMATION_TTL_SECONDS=300

# Alert retention window in days. Rows in alerts_sent older than this
# are eligible for deletion by the retention job. Default: 90.
ALERT_RETENTION_DAYS=90

# Max confirmed subscriptions per Telegram chat (soft anti-abuse limit).
# Default: 10.
MAX_SUBSCRIPTIONS_PER_CHAT=10

# HTTP API port. Used by the Nuxt app to create confirmation links.
# Default: 8787.
WATCHER_HTTP_PORT=8787

# Comma-separated allowed CORS origins for the HTTP API.
# Default: http://localhost:3000
WATCHER_CORS_ORIGIN=http://localhost:3000

# Dispatcher polling interval in ms. Jitter of ±10% is added per tick
# to de-synchronise multiple dispatcher instances. Default: 5000.
WATCHER_POLL_INTERVAL_MS=5000

# Max new delegation events processed per tick. Default: 100.
WATCHER_DISPATCH_BATCH_SIZE=100

# Retention sweep interval in ms. Default: 3600000 (1 hour).
WATCHER_RETENTION_SWEEP_INTERVAL_MS=3600000

# Max alerts_sent rows deleted per retention sweep iteration.
# The sweep repeats until affected_rows = 0. Default: 10000.
WATCHER_RETENTION_SWEEP_BATCH_SIZE=10000
