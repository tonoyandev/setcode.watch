# Per-chain RPC URLs — required for each monitored chain. The indexer
# refuses to boot if any of these are unset.
ETH_RPC_URL=
OP_RPC_URL=
BASE_RPC_URL=
ARB_RPC_URL=

# Optional fallbacks — Ponder fails over to these when the primary RPC
# starts erroring (rate limits, 5xx, etc.). At least one fallback per
# chain is strongly recommended for production.
ETH_RPC_FALLBACK_1=
ETH_RPC_FALLBACK_2=
OP_RPC_FALLBACK_1=
OP_RPC_FALLBACK_2=
BASE_RPC_FALLBACK_1=
BASE_RPC_FALLBACK_2=
ARB_RPC_FALLBACK_1=
ARB_RPC_FALLBACK_2=

# Per-chain start blocks — required, must be >= 1.
#
# Use the Pectra-equivalent activation block (or later) so the indexer
# skips pre-EIP-7702 history. Verify each value before setting:
#
#   Ethereum mainnet: ~22,431,084 (Pectra)  — etherscan.io
#   Optimism:         lookup the post-Isthmus block on optimistic.etherscan.io
#   Base:             lookup the post-Pectra block on basescan.org
#   Arbitrum One:     lookup the post-Pectra block on arbiscan.io
#
# Setting any of these unset (or below 1) will refuse to boot.
ETH_START_BLOCK=
OP_START_BLOCK=
BASE_START_BLOCK=
ARB_START_BLOCK=

# Contract addresses — optional, mainnet-only.
# Unset: the relevant handler is skipped with a console warning and dashboard
# features that depend on it fall back to off-chain data. These contracts are
# optional for MVP; deploy them when ready and populate these vars.
DELEGATION_CANARY_ADDRESS=
SETCODE_REGISTRY_ADDRESS=

# Postgres — required for production. Leave blank for local pglite.
DATABASE_URL=
