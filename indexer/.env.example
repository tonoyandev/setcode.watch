# Ethereum RPC — required
ETH_RPC_URL=

# Optional fallbacks (at least one recommended for production)
ETH_RPC_FALLBACK_1=
ETH_RPC_FALLBACK_2=

# Indexer start block — required, must be >= 22000000
#
# For Ethereum mainnet, use the Pectra activation block. As of early 2026
# the widely-cited value is ~22,431,084 but this is NOT authoritative here.
# Verify the exact value before setting:
#   https://etherscan.io/block/22431084
#   https://blog.ethereum.org/2025/04/30/pectra-mainnet
#
# Setting this below 22_000_000 will be rejected. Leaving it unset will
# refuse to boot.
PONDER_START_BLOCK=

# Contract addresses — optional.
# Unset: the relevant handler is skipped with a console warning and dashboard
# features that depend on it fall back to off-chain data. These contracts are
# optional for MVP; deploy them when ready and populate these vars.
DELEGATION_CANARY_ADDRESS=
SETCODE_REGISTRY_ADDRESS=

# Postgres — required for production. Leave blank for local pglite.
DATABASE_URL=
