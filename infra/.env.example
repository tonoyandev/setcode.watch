# SetCode.watch self-host — compose env template.
#
# Copy to infra/.env and fill in the required values. Anything left blank
# with a `?required` marker in docker-compose.yml will abort `docker compose
# up` with a clear error message; the optional knobs below fall back to
# sensible defaults if omitted.
#
# DO NOT commit infra/.env. It's already covered by .gitignore.

# ---------- required ----------

# Public hostname. Must resolve via DNS A/AAAA to this host before `up`;
# Caddy will request an ACME cert for this exact name at startup.
DOMAIN=watch.example.com

# Let's Encrypt contact — expiration + policy notices go here.
ACME_EMAIL=ops@example.com

# Postgres password. User and db default to `setcode` but can be overridden.
POSTGRES_PASSWORD=change-me-to-a-long-random-string

# Telegram bot credentials from @BotFather.
TELEGRAM_BOT_TOKEN=123456:AA-replace-me
TELEGRAM_BOT_USERNAME=YourBotName

# Reown (WalletConnect) project ID. Free at https://cloud.reown.com.
# Without it the Connect Wallet button falls back to injected wallets only
# (MetaMask / Rabby / browser wallets); WalletConnect v2 mobile flows are off.
NUXT_PUBLIC_REOWN_PROJECT_ID=

# Ethereum JSON-RPC endpoints. URL must support `eth_getLogs` with reasonable
# range limits (Alchemy, Infura, QuickNode, your own node, …). Fallbacks are
# used by Ponder in round-robin on primary failure — leave blank to skip.
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-key
ETH_RPC_FALLBACK_1=
ETH_RPC_FALLBACK_2=

# Earliest block the indexer scans. EIP-7702 went live on Pectra (~block
# 22615247 on mainnet). Pick a block at or after mainnet activation to avoid
# wasting scans on pre-Pectra history. Hardcap your RPC's earliest-allowed
# range in mind.
PONDER_START_BLOCK=22615247

# ---------- optional ----------

# Postgres user / db names. Change only if you care.
POSTGRES_USER=setcode
POSTGRES_DB=setcode

# Known target contracts surfaced in /registry and scored by the classifier.
# Leave blank for mainnet defaults (shared/src/registry.ts) to apply.
DELEGATION_CANARY_ADDRESS=
SETCODE_REGISTRY_ADDRESS=

# Watcher tuning knobs — defaults work well for a small instance.
CONFIRMATION_TTL_SECONDS=300
ALERT_RETENTION_DAYS=90
MAX_SUBSCRIPTIONS_PER_CHAT=10
WATCHER_POLL_INTERVAL_MS=5000
WATCHER_DISPATCH_BATCH_SIZE=100
WATCHER_RETENTION_SWEEP_INTERVAL_MS=3600000
WATCHER_RETENTION_SWEEP_BATCH_SIZE=10000
