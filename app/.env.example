# Base URL of the @setcode/watcher HTTP API. The Nuxt server and the browser
# both hit this origin; it must be reachable from both. Default targets the
# watcher dev server on localhost.
NUXT_PUBLIC_WATCHER_API_URL=http://localhost:8787

# Telegram bot username (without @). Used when building `t.me/<bot>?start=…`
# deep-links shown in the Subscribe / Watch CTAs.
NUXT_PUBLIC_BOT_USERNAME=setcode_watch_bot

# Reown (formerly WalletConnect) project ID. Free for open-source projects at
# https://cloud.reown.com — create a project, paste the ID here.
# Without it the Connect Wallet button still works for injected wallets
# (MetaMask, Rabby, Brave) but WalletConnect v2 mobile flows are disabled.
NUXT_PUBLIC_REOWN_PROJECT_ID=
